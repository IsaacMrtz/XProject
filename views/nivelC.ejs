<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= data.titulo %></title>
  <link rel="stylesheet" href="/resources/css/nivelC.css">
</head>
<body>
  <%- include('partials/nav2') %>
  <main>
    <div class="page-wrapper">
          <div class="nivelC-container"> 

        
          <section class="nivelC-main">
            

            <div class="path-wrapper zigzag-wrapper">
              <% lecturas.forEach((lec, idx) => { %>
                <a href="/layout?grado=<%= grado %>&id=<%= lec.id %>"
                  class="lesson-button <%= lec.estado %>"
                  style="--delay: <%= (idx * 0.15).toFixed(2) %>s">
                  <button class="btn-lesson">
                    <span class="icon"><%= lec.icono || '📖' %></span>
                  </button>
                  <div class="bubble"><%= lec.titulo %></div>
                </a>
              <% }) %>
            </div>

            
          </section>

          <aside class="nivelC-sidebar">
            <div class="stat-card">📚 Lecturas: <%= stats.lecturasLeidas %> / <%= stats.totalLecturas %></div>
            <br>
            <div class="stat-card">🎮 Juegos: <%= stats.juegosJugados %></div>
            <br>
            <div class="stat-card">🏅 Nivel: <%= stats.nivelActual %></div>
            <br>
            <div class="stat-card">🚀 Desafíos: <%= stats.desafiosActivos %></div>
            <br>
            <div class="botones-regreso">
              <a href="javascript:history.back()" class="btn-back">← Regresar</a>
            </div>
          </aside>
        </div>
    </div>
    
  </main>

  </body>
</html>