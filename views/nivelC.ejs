<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= data.titulo %></title>

  <!-- estilos globales (variables, tipografía, sidebar) -->
  
  <link rel="stylesheet" href="/resources/css/navbar.css">
  <!-- estilos específicos de esta vista -->
  <link rel="stylesheet" href="/resources/css/nivelC.css">
</head>
<body>
  <!-- Navbar vertical -->
  <%- include('partials/nav2') %>

  <!-- Wrapper de contenido dividido en 2 columnas -->
  <main class="nivelC-container">

    <!-- 1) Contenido principal -->
    <section class="nivelC-main">
      <!-- 1) Contenido principal <h1 class="titulo-principal"><%= data.titulo %></h1>
      <p class="descripcion"><%= data.descripcion %></p>   -->

      <h2 class="subtitulo">Lee y aprende</h2>
      <div class="botones-lecturas">
        <% if (!lecturas || lecturas.length === 0) { %>
          <p>No hay lecturas disponibles.</p>
        <% } else { %>
          <% lecturas.forEach(lec => { %>
            <a
              href="/layout?grado=<%= grado %>&id=<%= lec.id %>"
              class="btn-lectura"
            >
              <%= lec.titulo %>
            </a>
          <% }) %>

          <a href="/layout?grado=<%= grado %>" class="btn-lectura-outline">
            Leer todas las lecturas
          </a>
        <% } %>
      </div>

      <div class="botones-regreso">
        <a href="javascript:history.back()" class="btn-back">← Regresar</a>
      </div>
    </section>

    <!-- 2) Panel derecho de estadísticas -->
    <aside class="nivelC-sidebar">
      <div class="stat-card">
        <h3>📚 Lecturas</h3>
        <p></p>
      </div>
      <div class="stat-card">
        <h3>🎮 Juegos</h3>
        <p></p>
      </div>
      <div class="stat-card">
        <h3>🏅 Nivel</h3>
        <p>Nivel </p>
      </div>
      <div class="stat-card">
        <h3>🚀 Desafíos</h3>
        <p><</p>
      </div>
    </aside>

  </main>
</body>
</html>
